# Copy to .env and set your MongoDB connection string and admin creds
# IMPORTANT: Do NOT commit your real `.env` file. Keep credentials secret.
# Examples:
# For local MongoDB: MONGO_URI=mongodb://localhost:27017/your-db-name
# For Atlas: MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/your-db-name?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/mami-food
PORT=5000
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123456789
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=1d